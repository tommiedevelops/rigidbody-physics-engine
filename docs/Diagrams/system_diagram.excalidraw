    {
      "id": "XHutGSsM9Rsi-BmEbPn-l",
      "type": "text",
      "x": 2456.0127188974698,
      "y": -2448.8938148783564,
      "width": 553.4007568359374,
      "height": 280,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
