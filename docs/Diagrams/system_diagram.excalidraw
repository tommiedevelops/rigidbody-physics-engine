      "seed": 1226435198,
      "version": 530,
      "versionNonce": 1011640574,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1778204098533,
      "link": null,
      "locked": false,
      "text": "A broad phase collision detector\nwhich identifies potential pairs of rigid-\nbodies in collision.\n\nA narrow phase detector which detects\nwhether a pair of primitive colliders\n(sphere, box, plane) are in collision\n",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A broad phase collision detector\nwhich identifies potential pairs of rigid-\nbodies in collision.\n\nA narrow phase detector which detects\nwhether a pair of primitive colliders\n(sphere, box, plane) are in collision\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "Wr7Y7B5ohk0mBJH7V-9d8",
      "type": "text",
      "x": 2890.298389586641,
      "y": -2831.7510449285774,
      "width": 455.97979736328125,
      "height": 210,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4R",
      "roundness": null,
      "seed": 1244184958,
      "version": 367,
      "versionNonce": 2070008290,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1778204175356,
      "link": null,
      "locked": false,
      "text": "Based on collision data (contact\nnormal, restitution, contact point\netc.) applies correct linear and \nangular impulses and interpenet-\nration resolution to Rigidbodies\nto correctly resolve each collision",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Based on collision data (contact\nnormal, restitution, contact point\netc.) applies correct linear and \nangular impulses and interpenet-\nration resolution to Rigidbodies\nto correctly resolve each collision",
      "autoResize": true,
      "lineHeight": 1.25
    }
